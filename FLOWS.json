        "multi_prompt": {
            "then": [
                "split into independent intents",
                "classify each intent through WORKFLOW.json",
                "execute in dependency order",
                "verify and report one coherent result"
            ]
        },
        "direct_answer": {
            "then": [
                "load bootstrap indexes",
                "answer from loaded context",
