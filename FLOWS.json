            ]
        },
        "documentation_edit": {
            "then": [
                "load DOCS.json",
                "read target owner document",
                "use JSON-aware document tooling",
                "normalize and verify"
            ]
        },
        "implementation": {
            "then": [
                "load WORKFLOW.json",
                "load code guidance when source code may change",
                "inspect scripts before manual work",
                "edit scoped files",
                "verify"
            ]
        },
        "broad_refactor": {
            "then": [
                "confirm high-cost scope when not already confirmed",
                "create passes",
                "edit in coherent slices",
                "update affected contracts",
                "finalize"
            ]
        },
        "pipeline_upgrade": {
            "then": [
                "audit source state",
                "migrate structured contracts to JSON",
                "port routing/index scripts",
                "generalize default code behavior",
                "add explicit project types",
                "recompile generated outputs",
                "run finalizer"
            ]
        },
        "review": {
            "then": [
                "inspect diff or target files",
                "lead with findings",
                "include verification gaps",
                "avoid unrelated rewrites"
            ]
        },
        "quality_diagnostics": {
            "then": [
                "run the relevant script",
                "inspect failures",
                "fix repeatable tooling failures in the owning tool",
