        "sync_managed_pipeline_package.ps1": {
            "path": "tools/pipeline/sync_managed_pipeline_package.ps1",
            "category": "pipeline",
            "description": "Mirror source-owned SocratexAI package paths into an installed child pipeline, deleting stale files only inside managed paths.",
            "input": {
                "required": [
                    "-SourceRoot",
                    "-InstallRoot"
                ],
                "optional": [
                    "-ManagedPaths",
                    "-DryRun"
                ],
                "rule": "Use only for source-owned SocratexAI package paths; project memory and configuration outside SocratexAI remain child-owned."
            },
            "output": {
                "success": "Prints mirrored managed paths and OK when complete.",
                "failure": "Throws on unsafe destination paths or copy/remove failures."
            }
        },
        "check_pipeline_feature_contracts.ps1": {
            "path": "tools/repo/check_pipeline_feature_contracts.ps1",
            "category": "repo",
            "description": "Validate pipeline_featurelist.json feature artifact contracts and ensure changed pipeline-owned paths are assigned to at least one feature contract.",
            "input": {
                "required": [],
                "optional": [
                    "-Paths"
                ],
                "rule": "Pass changed paths when checking a focused task; omit paths for a full feature contract audit."
            },
            "output": {
                "success": "Prints the number of covered feature contracts and confirms changed pipeline paths are assigned.",
                "failure": "Throws when a feature lacks contract fields, required artifacts are missing, catalog entries are absent, or changed pipeline paths are uncovered."
            }
        },
        "tool_handler.ps1": {
            "path": "tools/pipeline/tool_handler.ps1",
            "category": "pipeline",
            "description": "Public single entry point for repository tool operations; validates inputs, normalizes parameters and aliases, delegates to the target script, logs input errors, and returns a stable result envelope.",
            "input": {
                "required": [
                    "-Operation"
                ],
                "optional": [
                    "-ParametersJson",
                    "-ParametersJsonFile",
                    "-OutputMode",
                    "-ErrorLogPath",
                    "-NoErrorLog"
                ],
                "rule": "Use exactly one of -ParametersJson or -ParametersJsonFile. Prefer -ParametersJsonFile for nested, multiline, or quote-heavy parameter payloads."
            },
            "output": {
                "success": "Structured result envelope with ok=true, normalized operation, target script, normalized parameters, command, exit code, and captured output.",
                "failure": "Structured result envelope with ok=false, error type/message, and logged_error_key when validation logged an input failure."
            }
        },
        "tool_error_log.ps1": {
            "path": "tools/pipeline/tool_error_log.ps1",
            "category": "pipeline",
            "description": "Append a tool invocation or result-contract failure to docs-tech/TOOL-ERRORS.json, defaulting to the parent project registry when running from an installed SocratexAI package.",
            "input": {
                "required": [],
                "optional": [
                    "-Path",
                    "-Key",
                    "-Title",
                    "-Status",
                    "-Tool",
                    "-Failure",
                    "-FailingCommandShape",
                    "-ObservedError",
                    "-SuspectedContractGap",
                    "-FixTarget",
                    "-DetailsJson",
                    "-DetailsJsonFile",
                    "-ObservedAt",
                    "-Json"
                ],
                "rule": "Omit -Path for the default tool-error registry. Use -DetailsJsonFile for nested, multiline, or quote-heavy payloads; valid JSON is stored as structured data and invalid JSON is stored as text."
            },
            "output": {
                "success": "OK text or JSON with the inserted key and target path.",
                "failure": "Throws if the registry cannot be initialized or the entry cannot be appended."
            }
        },
        "read_compiled_context.ps1": {
            "path": "tools/pipeline/read_compiled_context.ps1",
            "category": "pipeline",
            "description": "Read a source compiled instruction file or a compact source context document by alias.",
            "input": {
                "required": [
                    "-Document"
                ],
                "optional": [
                    "-CompiledRoot",
                    "-AllowStale",
                    "-Json"
                ],
                "aliases": "When called through tool_handler.ps1, aliases such as scripts, commands, flows, docs, workflow, rules, entrypoint, bootstrap, engineering, and agent_contract are normalized before invocation.",
                "rule": "Prefer tool_handler.ps1 for normal use so aliases and stale checks are normalized before this script runs."
            },
            "output": {
                "success": "Compiled or source context content by default, or JSON with selected path and content when -Json is used.",
                "failure": "Throws when no alias/path matches or when a compiled output hash is stale."
            }
        }
    },
