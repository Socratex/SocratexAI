            "category": "documents",
            "description": "Insert a document item; routes .json paths through json_item_insert.ps1/json_item_set.ps1 and non-JSON slim documents through document_item_edit_engine.py.",
            "input": {
                "required": [
                    "-Path",
                    "-Key"
                ],
                "optional": [
                    "-Title",
                    "-Content",
                    "-ContentFile",
                    "-ItemFile",
                    "-Position",
                    "-Before",
                    "-After",
                    "-AllowEmpty",
                    "-Replace",
                    "-NoPostEdit"
                ],
                "json_routing": "For .json paths, -Title/-Content/-ContentFile are wrapped as {title, content}; -ItemFile must contain a JSON value; -Replace routes to json_item_set.ps1; insert routes to json_item_insert.ps1.",
                "rule": "Use -ContentFile or -ItemFile for multiline or quote-heavy content. For direct JSON control, use json_item_insert.ps1/json_item_set.ps1."
            },
            "output": {
                "success": "OK from the underlying document editor.",
                "failure": "Throws child editor failure with the child process exit code."
            }
