        "json_list_doc.py": {
            "path": "tools/documents/json_list_doc.py",
            "description": "Edit and read list-style JSON source documents while preserving collection order and root indexes.",
            "input": {
                "commands": [
                    "read",
                    "insert-entry",
                    "set-entry",
                    "move-entry",
                    "delete-entry",
                    "refresh-index",
                    "migrate-content",
                    "insert-line",
                    "set-line",
                    "move-line"
                ],
                "value_sources": [
                    "--text",
                    "--value-json",
                    "--value-json-file",
                    "--value-json-stdin"
                ],
                "preferred_structured_value_source": "--value-json-file or --value-json-stdin for multiline, nested, or quote-heavy JSON.",
                "rule": "Use exactly one value source per insert-entry or set-entry call."
            },
            "output": {
                "read": "JSON payload printed to stdout.",
                "mutation_success": "OK: operation target.",
                "failure": "Non-zero exit with ERROR message on stderr/stdout from the Python wrapper."
            },
            "category": "documents"
        },
